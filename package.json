{
    "name": "typescript-llm",
    "version": "0.1.0",
    "description": "Mini LLM pédagogique en TypeScript pour comprendre progressivement les mécanismes des LLM modernes.",
    "type": "module",
    "private": true,
    "packageManager": "npm@11.9.0",
    "engines": {
        "node": ">=24 <25",
        "npm": ">=11"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "demo:01-tokenizer": "tsx src/modules/01-tokenizer-simple/demo.ts",
        "demo:02-dataset": "tsx src/modules/02-dataset-loader/demo.ts",
        "demo:03-bigram": "tsx src/modules/03-bigram-model/demo.ts",
        "demo:04-embeddings": "tsx src/modules/04-embeddings/demo.ts",
        "demo:05-attention": "tsx src/modules/05-self-attention/demo.ts",
        "demo:06-transformer-block": "tsx src/modules/06-transformer-block/demo.ts",
        "demo:07-positional-encoding": "tsx src/modules/07-positional-encoding/demo.ts",
        "demo:08-training-loop": "tsx src/modules/08-training-loop-cpu/demo.ts",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^24.10.1",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.0.15"
    }
}
