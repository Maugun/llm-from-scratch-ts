{
    "name": "typescript-llm",
    "version": "0.1.0",
    "description": "Mini LLM pédagogique en TypeScript pour comprendre progressivement les mécanismes des LLM modernes.",
    "type": "module",
    "private": true,
    "packageManager": "npm@10.8.2",
    "engines": {
        "node": ">=20 <25",
        "npm": ">=10 <12"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "corpus:clean": "tsx src/tools/corpus-cleaner.ts",
        "demo:01-tokenizer": "tsx src/modules/01-tokenizer-simple/demo.ts",
        "demo:02-dataset": "tsx src/modules/02-dataset-loader/demo.ts",
        "demo:03-bigram": "tsx src/modules/03-bigram-model/demo.ts",
        "demo:04-embeddings": "tsx src/modules/04-embeddings/demo.ts",
        "demo:05-attention": "tsx src/modules/05-self-attention/demo.ts",
        "demo:06-transformer-block": "tsx src/modules/06-transformer-block/demo.ts",
        "demo:07-positional-encoding": "tsx src/modules/07-positional-encoding/demo.ts",
        "demo:08-training-loop": "tsx src/modules/08-training-loop-cpu/demo.ts",
        "demo:09-minimal-lm": "tsx src/modules/09-minimal-trainable-language-model/demo.ts",
        "demo:10-text-generation": "tsx src/modules/10-text-generation/demo.ts",
        "demo:11-sampling": "tsx src/modules/11-sampling-strategies/demo.ts",
        "demo:12-tfjs-autograd": "tsx src/modules/12-tensorflow-autograd/demo.ts",
        "demo:13-tfjs-next-token": "tsx src/modules/13-tfjs-next-token-model/demo.ts",
        "demo:14-mini-transformer": "tsx src/modules/14-trainable-mini-transformer/demo.ts",
        "demo:15-model-sizing": "tsx src/modules/15-model-sizing-memory-estimator/demo.ts",
        "demo:16-tfjs-node-gpu": "tsx src/modules/16-tfjs-node-gpu-backend/demo.ts",
        "demo:17-long-corpus": "tsx src/modules/17-long-corpus-pipeline/demo.ts",
        "demo:18-small-real-model": "tsx src/modules/18-small-real-model-training/demo.ts",
        "demo:18-small-real-model:continue": "npm run demo:18-small-real-model -- --continue-train",
        "demo:18-small-real-model:train": "npm run demo:18-small-real-model -- --force-train",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "gpu:demo": "npm run demo:16-tfjs-node-gpu",
        "gpu:install": "npm install @tensorflow/tfjs-node-gpu@4.22.0 --no-save",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/node": "^20.19.41",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vitest": "^4.0.15"
    },
    "dependencies": {
        "@tensorflow/tfjs": "^4.22.0"
    }
}
