{
    "corpusPath": "data/private/long-corpus.clean.txt",
    "checkpointPath": "data/checkpoints/final-tiny-llm",
    "bpeVocabularySize": 1000,
    "bpeMaxTrainingCharacters": 300000,
    "bpeMinimumMergeCount": 10,
    "bpeMaximumMergedTokenLength": 24,
    "bpeMaximumSpacesInMergedToken": 1,
    "contextLength": 128,
    "batchSize": 16,
