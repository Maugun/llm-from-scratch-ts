    "maxTrainBatchesPerEpoch": 100,
    "maxValidationBatches": 10,
    "saveBestEpochOnly": true,
    "skipCheckpointWhenNoImprovement": true,
    "validationRatio": 0.05,
    "batchOrder": "shuffled",
    "shuffleSeed": 19,
    "maxNewTokens": 200,
    "strategy": "topK",
    "temperature": 0.9,
    "topK": 20,
    "seed": 19,
    "prompt": "Utilisateur: Bonjour\nAssistant:"
}
